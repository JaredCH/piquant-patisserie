# =============================================================================
# The Piquant Patisserie — Environment Variables
# Copy this file to .env and fill in real values before running.
# =============================================================================

# --- Admin Panel Credentials ---
ADMIN_USER=admin
ADMIN_PASS=changeme

# --- Session Secret (generate a long random string) ---
SESSION_SECRET=replace-with-a-long-random-secret-string

# --- Stripe Keys (test mode by default) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# --- SMTP Email Configuration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=hello@thepiquantpatisserie.com

# --- Server ---
PORT=3000
